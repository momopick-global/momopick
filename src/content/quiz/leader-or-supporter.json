  "results": {
    "A": {
      "emoji": "🎯",
      "scoreKey": "A",
      "title": {
        "ko": "리더",
        "en": "Leader"
      },
      "tagline": {
        "ko": "방향을 제시하고 팀을 이끄는 타입",
        "en": "You set direction and take the lead"
      },
      "body": {
        "ko": "방향을 제시하고 팀을 이끄는 타입입니다. 책임감과 추진력이 강한 편입니다.\n프로젝트를 시작할 때 먼저 방향을 잡고, 문제가 생기면 바로 해결하려는 흐름이 나올 수 있어요.\n의사결정에서 결론을 내리고, 갈등에서는 결론을 이끄는 역할을 맡는 경우가 많습니다.\n일할 때 전체를 보고, 성과를 낼 때도 주도적으로 만드는 편입니다.\n앞에서 이끄는 자리가 더 편하게 느껴질 수 있어요.",
        "en": "You lead, set direction, and take responsibility.\nYou may set direction first when a project starts and move fast when problems appear.\nIn decisions you make the call; in conflict you drive toward a conclusion.\nYou tend to see the big picture and lead outcomes.\nBeing up front may feel more natural than staying in the background."
      },
      "image": "/images/quiz/leader-or-supporter/result-1.webp",
      "share": {
        "title": {
          "ko": "나의 팀 포지션은 리더형",
          "en": "My team role is Leader"
        },
        "description": {
          "ko": "방향을 제시하고 팀을 이끄는 타입",
          "en": "You lead and take responsibility"
        },
        "image": "/images/quiz/leader-or-supporter/result-1.webp"
      }
    },

    "B": {
      "emoji": "🧭",
      "scoreKey": "B",
      "title": {
        "ko": "전략가",
        "en": "Strategist"
      },
      "tagline": {
        "ko": "흐름을 읽고 조율하는 타입",
        "en": "You read the flow and coordinate"
      },
      "body": {
        "ko": "전체 흐름을 읽고 조율하는 타입입니다. 균형과 판단력이 뛰어납니다.\n문제가 생기면 원인을 분석하고, 의사결정에서는 여러 의견을 정리하거나 중간에서 다리를 놓는 역할이 잘 맞을 수 있어요.\n팀원과의 관계에서 조율자로 서고, 일할 때는 구조를 만드는 쪽에 강점이 있습니다.\n갈등에서는 중재하고, 성과는 전략적으로 설계하는 흐름이 나올 수 있어요.\n앞과 뒤 사이, 중간에서 균형을 잡는 자리가 편할 수 있습니다.",
        "en": "You analyze and balance situations with strong judgment.\nWhen problems arise you dig into causes; in decisions you organize views or bridge sides.\nYou often mediate with teammates and build structure in how work gets done.\nIn conflict you mediate; with results you plan strategically.\nCoordinating from the middle may feel like your sweet spot."
      },
      "image": "/images/quiz/leader-or-supporter/result-2.webp",
      "share": {
        "title": {
          "ko": "나의 팀 포지션은 전략가형",
          "en": "My team role is Strategist"
        },
        "description": {
          "ko": "전체 흐름을 읽고 조율하는 타입",
          "en": "You analyze and coordinate"
        },
        "image": "/images/quiz/leader-or-supporter/result-2.webp"
      }
    },

    "C": {
      "emoji": "🤝",
      "scoreKey": "C",
      "title": {
        "ko": "서포터",
        "en": "Supporter"
      },
      "tagline": {
        "ko": "팀을 안정적으로 돕는 타입",
        "en": "You keep the team steady through support"
      },
      "body": {
        "ko": "팀을 안정적으로 유지시키는 타입입니다. 배려와 협력이 강점입니다.\n프로젝트 시작 때 필요한 역할을 찾거나 분위기를 보며, 문제가 생기면 주변을 돕는 쪽으로 움직일 수 있어요.\n의사결정에서는 다른 사람 의견을 따르거나 중간을 선택하고, 팀원과는 도와주는·편한 동료 역할에 가깝습니다.\n실행을 돕고 요청받은 일에 집중하는 흐름, 갈등에서는 뒤에서 돕거나 피하는 선택도 나올 수 있어요.\n뒤에서 지원하거나 눈에 덜 띄는 자리가 더 편하게 느껴질 수 있습니다.",
        "en": "You support others and keep the team stable.\nWhen projects start you find where you can help or read the room; when trouble hits you lift others up.\nIn decisions you may follow the group or pick the middle path; with teammates you are helpful and easy to work with.\nYou help execution, focus on assigned work, and in conflict you may support quietly or step back.\nSupporting from behind or staying low-key can feel most comfortable."
      },
      "image": "/images/quiz/leader-or-supporter/result-3.webp",
      "share": {
        "title": {
          "ko": "나의 팀 포지션은 서포터형",
          "en": "My team role is Supporter"
        },
        "description": {
          "ko": "팀을 안정적으로 돕는 타입",
          "en": "You support and collaborate"
        },
        "image": "/images/quiz/leader-or-supporter/result-3.webp"
      }
    }
  },

  "blend": {
    "emoji": "✨",
    "scoreKey": "blend",
    "title": {
