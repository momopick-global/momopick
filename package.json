{
  "name": "momopick",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next .next-dev out",
    "free:3040": "lsof -ti :3040 | xargs kill -9 2>/dev/null || true",
    "dev:fresh": "npm run clean && next dev -p 3040",
    "dev:reset": "npm run free:3040 && npm run clean && npm run dev",
    "fix": "npm run dev:reset",
    "dev": "next dev -p 3040",
    "dev:turbo": "next dev -p 3040 --turbopack",
    "build": "next build",
    "deploy:pages": "npm run build && npx wrangler pages deploy out",
    "preview": "serve out -l 3040",
    "lint": "next lint",
    "lint:all": "eslint .",
    "check:quiz-images": "node tools/check-quiz-images.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "next": "^15.5.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.10",
    "serve": "^14.2.4",
    "typescript": "^5.7.0"
  }
}
