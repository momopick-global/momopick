# Supabase (대시보드 → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 카카오 JavaScript SDK (카카오 디벨로퍼스 → 앱 설정 → 앱 키 → JavaScript 키만 사용)
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=

# 카카오 공유 링크 정규화용 운영 origin (로컬에서 공유 시 momopick.com 링크로 보냄). 기본 https://momopick.com
# NEXT_PUBLIC_SITE_ORIGIN=https://momopick.com

# Cloudflare Pages 대시보드 → Settings → Environment variables 에도 동일 키 등록
