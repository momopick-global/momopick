# Supabase (대시보드 → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Google 로그인: Authentication → Providers → Google 활성화
# Authentication → URL Configuration → Redirect URLs 에 예시 추가:
#   http://localhost:3040/ko/app/login/oauth/
#   https://momopick.com/ko/app/login/oauth/

# 카카오 JavaScript SDK (카카오 디벨로퍼스 → 앱 설정 → 앱 키 → JavaScript 키만 사용)
# 중요: NEXT_PUBLIC_* 는 `next build` 시점에 JS에 박힙니다. Pages 대시보드에만 넣고 재배포하지 않으면 운영에서 카카오 공유가 안 되고 링크 복사 폴백만 동작합니다.
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=

# 카카오 공유 링크 정규화용 운영 origin (로컬에서 공유 시 momopick.com 링크로 보냄). 비우면 기본 https://momopick.com
NEXT_PUBLIC_SITE_ORIGIN=

# Cloudflare Pages → Settings → Environment variables 에 위 키를 **Production**(및 Preview 필요 시)에 넣고 **새로 배포**할 것
